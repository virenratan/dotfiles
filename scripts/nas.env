# Shared NAS configuration for scripts.
export NAS_HOST="192.168.1.135"
export NAS_USER="viren"
export NAS_SSH_KEY_NAME="nas-cleanup"

# convenience variable for ssh target.
export NAS_SSH_TARGET="$NAS_USER@$NAS_HOST"

# dedicated ssh key for nas automation. override by exporting NAS_SSH_KEY before running.
export NAS_SSH_KEY="${NAS_SSH_KEY:-$HOME/.ssh/$NAS_SSH_KEY_NAME}"

# centralize ssh invocation options and binary.
# - IdentitiesOnly avoids cycling through 1Password agent keys.
# - BatchMode avoids interactive prompts in automation.
export NAS_SSH_BIN="${NAS_SSH_BIN:-/usr/bin/ssh}"
export NAS_SSH_OPTS="${NAS_SSH_OPTS:--o IdentitiesOnly=yes -o BatchMode=yes}"
